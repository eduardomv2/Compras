<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:Compras.Views"
       x:Class="Compras.AppShell"
       Shell.NavBarIsVisible="False">

    <!-- Página inicial: Login -->
    <ShellContent Title="Login"
                  ContentTemplate="{DataTemplate views:LoginPage}"
                  Route="LoginPage"/>

    <!-- Tab bar principal (visible después del login) -->
    <TabBar Route="Main">
        <ShellContent Title="Inicio"
                      Route="CatalogoPage"
                      ContentTemplate="{DataTemplate views:CatalogoPage}">
            <ShellContent.Icon>
                <FontImageSource Glyph="⌂" Color="#001F3F" Size="20"/>
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent Title="Carrito"
              Route="CarritoPage"
              ContentTemplate="{DataTemplate views:CarritoPage}">
            <ShellContent.Icon>
                <FontImageSource Glyph="🛒" Color="#001F3F" Size="20"/>
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent Title="Mis Pedidos"
              Route="MisPedidosPage"
              ContentTemplate="{DataTemplate views:MisPedidosPage}">
            <ShellContent.Icon>
                <FontImageSource Glyph="📦" Color="#001F3F" Size="20"/>
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>

</Shell>