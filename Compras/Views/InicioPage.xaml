<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Compras.ViewModels"
             xmlns:models="clr-namespace:Compras.Models"
             x:Class="Compras.Views.InicioPage"
             x:DataType="vm:InicioViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F2F2F2">

    <RefreshView Command="{Binding CargarCommand}"
                 IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Grid BackgroundColor="#001F3F" Padding="16,12">
                    <Label Text="TIENDA" FontSize="22" FontAttributes="Bold"
                           TextColor="#FFD700" HorizontalOptions="Start"
                           VerticalOptions="Center"/>
                </Grid>

                <!-- Carrusel de promociones -->
                <VerticalStackLayout Margin="0,12,0,0">
                    <CarouselView x:Name="carruselPromociones"
                                  ItemsSource="{Binding Promociones}"
                                  HeightRequest="160"
                                  Loop="True"
                                  IndicatorView="indicador">
                        <CarouselView.ItemTemplate>
                            <DataTemplate x:DataType="models:PromocionDto">
                                <Border Margin="16,0" BackgroundColor="#001F3F"
                StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InicioViewModel}}, Path=VerPromocionCommand}"
                    CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto" Padding="20">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="8">
                                            <Label Text="{Binding TextoDescuento}"
                           FontSize="36" FontAttributes="Bold" TextColor="#FFD700"/>
                                            <Label Text="{Binding NombreCampana}"
                           FontSize="16" TextColor="White" FontAttributes="Bold"/>
                                            <Label Text="{Binding TextoMinimo}"
                           FontSize="12" TextColor="#B0BEC5"/>
                                            <Label Text="Ver productos →"
                           FontSize="12" TextColor="#FFD700"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="🏷️" FontSize="48" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>

                    <!-- Indicadores del carrusel -->
                    <IndicatorView x:Name="indicador"
                                   HorizontalOptions="Center"
                                   IndicatorColor="#77777A"
                                   SelectedIndicatorColor="#001F3F"
                                   Margin="0,8,0,0"/>
                </VerticalStackLayout>


                <!-- Categorías -->
                <VerticalStackLayout Margin="32,16,32,0" Spacing="8">
                    <Grid ColumnDefinitions="*,auto">
                        <Label Text="Categorías" FontSize="18"
               FontAttributes="Bold" TextColor="#001F3F"/>
                        <Label Grid.Column="1" Text="Ver todas →"
               TextColor="#001F3F" FontSize="12"
               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding VerCatalogoCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                    <CollectionView ItemsSource="{Binding CategoriasDestacadas}">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                             Span="2"
                             HorizontalItemSpacing="6"
                             VerticalItemSpacing="6"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:CategoriaDto">
                                <Border BackgroundColor="#001F3F"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 16"
            Padding="12, 14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InicioViewModel}}, Path=VerCategoriaCommand}"
                CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="6" VerticalOptions="Center"
                             HorizontalOptions="Center">
                                        <Label Text="{Binding Nombre, Converter={StaticResource CategoriaEmojiConverter}}"
                   FontSize="28" HorizontalOptions="Center"/>
                                        <Label Text="{Binding Nombre}"
                   TextColor="White"
                   FontSize="12"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   MaxLines="1"/>
                                        <Label Text="{Binding Nombre, Converter={StaticResource CategoriaDescripcionConverter}}"
                   TextColor="#B0BEC5"
                   FontSize="10"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   MaxLines="1"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Productos destacados -->
                <VerticalStackLayout Margin="16,16,16,16" Spacing="8">
                    <CollectionView ItemsSource="{Binding Destacados}">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="2"
                                             HorizontalItemSpacing="8"
                                             VerticalItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ProductoDto">
                                <Border BackgroundColor="White"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="0">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InicioViewModel}}, Path=VerProductoCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout>
                                        <Image Source="{Binding ImagenPortada}"
                                               HeightRequest="130"
                                               Aspect="AspectFill"/>
                                        <VerticalStackLayout Padding="10,8" Spacing="4">
                                            <Label Text="{Binding Nombre}"
                                                   FontAttributes="Bold"
                                                   FontSize="13"
                                                   TextColor="#001F3F"
                                                   MaxLines="2"/>
                                            <Label Text="{Binding Marca}"
                                                   FontSize="11"
                                                   TextColor="#77777A"/>
                                            <Label Text="{Binding PrecioVenta, StringFormat='${0:N2}'}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="#001F3F"/>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>