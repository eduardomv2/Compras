<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Compras.ViewModels"
             xmlns:converters="clr-namespace:Compras.Converters"
             x:Class="Compras.Views.CheckoutPage"
             x:DataType="vm:CheckoutViewModel"
             Title="Checkout"
             BackgroundColor="#F2F2F2">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- Resumen -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Resumen del pedido"
                               FontAttributes="Bold" FontSize="16"
                               TextColor="#001F3F"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Total a pagar" TextColor="#77777A"/>
                            <Label Grid.Column="1"
                                   Text="{Binding Total, StringFormat='${0:N2}'}"
                                   FontAttributes="Bold" FontSize="18"
                                   TextColor="#001F3F"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding Descuento, Converter={StaticResource DecimalToBoolConverter}}">
                            <Label Text="Descuento aplicado" TextColor="#E3122B"/>
                            <Label Grid.Column="1"
                                   Text="{Binding Descuento, StringFormat='-${0:N2}'}"
                                   TextColor="#E3122B"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Datos de tarjeta -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Datos de tarjeta"
                               FontAttributes="Bold" FontSize="16"
                               TextColor="#001F3F"/>

                        <Entry Placeholder="Número de tarjeta"
                               Text="{Binding NumeroTarjeta}"
                               Keyboard="Numeric" MaxLength="16"
                               HeightRequest="52"/>

                        <Entry Placeholder="Nombre del titular"
                               Text="{Binding NombreTarjeta}"
                               HeightRequest="52"/>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Entry Grid.Column="0" Placeholder="MM"
                                   Text="{Binding MesExpiracion}"
                                   Keyboard="Numeric" MaxLength="2"
                                   HeightRequest="52"/>
                            <Entry Grid.Column="1" Placeholder="AA"
                                   Text="{Binding AnioExpiracion}"
                                   Keyboard="Numeric" MaxLength="2"
                                   HeightRequest="52"/>
                            <Entry Grid.Column="2" Placeholder="CVV"
                                   Text="{Binding Cvv}"
                                   IsPassword="True"
                                   Keyboard="Numeric" MaxLength="4"
                                   HeightRequest="52"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Método de pago -->
                <Border BackgroundColor="White" StrokeThickness="0"
        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Método de pago"
               FontAttributes="Bold" FontSize="16"
               TextColor="#001F3F"/>

                        <!-- Débito -->
                        <Border StrokeThickness="2"
                StrokeShape="RoundRectangle 8"
                Padding="12">
                            <Border.Stroke>
                                <Binding Path="EsDebito">
                                    <Binding.Converter>
                                        <converters:BoolToColorConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Border.Stroke>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SeleccionarDebitoCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="💳" FontSize="24"/>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="Débito" FontAttributes="Bold"
                           TextColor="#001F3F" FontSize="15"/>
                                    <Label Text="Pago de contado"
                           TextColor="#77777A" FontSize="12"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Crédito -->
                        <Border StrokeThickness="2"
        StrokeShape="RoundRectangle 8"
        Padding="12">
                            <Border.Stroke>
                                <Binding Path="EsCredito">
                                    <Binding.Converter>
                                        <converters:BoolToColorConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Border.Stroke>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SeleccionarCreditoCommand}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="12">
                                    <Label Text="🏦" FontSize="24"/>
                                    <VerticalStackLayout VerticalOptions="Center">
                                        <Label Text="Crédito tienda" FontAttributes="Bold"
                       TextColor="#001F3F" FontSize="15"/>
                                        <Label Text="{Binding CreditoDisponibleTexto}"
                       TextColor="#77777A" FontSize="12"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                                <Label Text="Pago a 12 meses • Próximamente MSI disponibles"
               TextColor="#77777A" FontSize="11"
               IsVisible="{Binding EsCredito}"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Error -->
                <Label Text="{Binding ErrorMensaje}"
                       TextColor="#E3122B"
                       IsVisible="{Binding ErrorMensaje, Converter={StaticResource StringToBoolConverter}}"
                       HorizontalOptions="Center"/>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#001F3F"/>

            </VerticalStackLayout>
        </Border>

        </VerticalStackLayout>
    </ScrollView>

        <!-- Botón pagar -->
        <Button Grid.Row="1"
                Text="PAGAR AHORA"
                Command="{Binding PagarCommand}"
                BackgroundColor="#FFD700"
                TextColor="#001F3F"
                FontAttributes="Bold"
                HeightRequest="56"
                CornerRadius="0"
                Margin="0"/>

    </Grid>
</ContentPage>