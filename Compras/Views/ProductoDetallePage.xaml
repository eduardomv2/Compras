<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Compras.ViewModels"
             x:Class="Compras.Views.ProductoDetallePage"
             x:DataType="vm:ProductoDetalleViewModel"
             Title="{Binding Titulo}"
             BackgroundColor="White">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Imagen -->
                <Image Source="{Binding Producto.ImagenPortada}"
                       HeightRequest="280"
                       Aspect="AspectFill"
                       BackgroundColor="#F2F2F2"/>

                <VerticalStackLayout Padding="20" Spacing="12">

                    <!-- Categoría -->
                    <Label Text="{Binding Producto.Categoria}"
                           FontSize="12" TextColor="#77777A"
                           FontAttributes="Bold"/>

                    <!-- Nombre -->
                    <Label Text="{Binding Producto.Nombre}"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="#001F3F"/>

                    <!-- Marca -->
                    <Label Text="{Binding Producto.Marca}"
                           FontSize="14" TextColor="#77777A"/>

                    <!-- Precio normal -->
                    <Label Text="{Binding Producto.PrecioVenta, StringFormat='${0:N2}'}"
                           FontSize="28" FontAttributes="Bold"
                           TextColor="#001F3F"
                           IsVisible="{Binding TieneDescuento, Converter={StaticResource InvertBoolConverter}}"/>

                    <!-- Precio con descuento -->
                    <VerticalStackLayout IsVisible="{Binding TieneDescuento}" Spacing="4">
                        <Label Text="{Binding Producto.PrecioVenta, StringFormat='${0:N2}'}"
                               FontSize="16" TextColor="#77777A"
                               TextDecorations="Strikethrough"/>
                        <HorizontalStackLayout Spacing="12">
                            <Label Text="{Binding PrecioConDescuento, StringFormat='${0:N2}'}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="#001F3F"/>
                            <Border BackgroundColor="#E3122B" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 4" Padding="8,4">
                                <Label Text="{Binding Producto.EsElectronica, Converter={StaticResource ElectronicaDescuentoConverter}}"
                                       TextColor="White" FontSize="13" FontAttributes="Bold"/>
                            </Border>
                        </HorizontalStackLayout>
                        <Label Text="{Binding MontoDescuento, StringFormat='Ahorras ${0:N2}'}"
                               TextColor="#E3122B" FontSize="13"/>
                    </VerticalStackLayout>

                    <!-- Stock -->
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="●" TextColor="{Binding ColorStock}" FontSize="12"/>
                        <Label Text="{Binding TextoStock}"
                               FontSize="13" TextColor="#77777A"/>
                    </HorizontalStackLayout>

                    <!-- Descripción -->
                    <BoxView HeightRequest="1" BackgroundColor="#F2F2F2" Margin="0,8"/>
                    <Label Text="Descripción" FontAttributes="Bold"
                           TextColor="#001F3F" FontSize="16"/>
                    <Label Text="{Binding Producto.Descripcion}"
                           TextColor="#444" FontSize="14" LineHeight="1.4"/>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Botones fijos abajo -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*"
              BackgroundColor="White" Padding="16,12"
              ColumnSpacing="12">
            <Button Grid.Column="0"
                    Text="AÑADIR AL CARRITO"
                    Command="{Binding AgregarAlCarritoCommand}"
                    IsEnabled="{Binding HayStock}"
                    BackgroundColor="{Binding HayStock, Converter={StaticResource BoolToColorConverter}}"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    CornerRadius="8"/>
            <Button Grid.Column="1"
                    Text="COMPRAR AHORA"
                    Command="{Binding ComprarAhoraCommand}"
                    IsEnabled="{Binding HayStock}"
                    BackgroundColor="{Binding HayStock, Converter={StaticResource BoolToColorConverter}}"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    CornerRadius="8"/>
        </Grid>

    </Grid>
</ContentPage>