<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Compras.ViewModels"
             x:Class="Compras.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#001F3F">

    <ScrollView>
        <Grid RowDefinitions="*,Auto,*" MinimumHeightRequest="700">

            <!-- Fondo decorativo superior -->
            <BoxView Grid.Row="0" Grid.RowSpan="3"
                     BackgroundColor="#001F3F"/>

            <!-- Círculo decorativo grande -->
            <Ellipse Grid.Row="0"
                     Fill="#0D2B45"
                     WidthRequest="400" HeightRequest="400"
                     HorizontalOptions="End"
                     VerticalOptions="Start"
                     Margin="0,-100,-100,0"/>

            <!-- Círculo decorativo pequeño -->
            <Ellipse Grid.Row="2"
                     Fill="#0D2B45"
                     WidthRequest="200" HeightRequest="200"
                     HorizontalOptions="Start"
                     VerticalOptions="End"
                     Margin="-60,0,0,0"/>

            <!-- Contenido principal -->
            <VerticalStackLayout Grid.Row="0" Grid.RowSpan="3"
                                 Padding="32,60,32,32"
                                 Spacing="0"
                                 VerticalOptions="Center">

                <!-- Logo -->
                <Border BackgroundColor="#FFD700"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        WidthRequest="72" HeightRequest="72"
                        HorizontalOptions="Center"
                        Margin="0,0,0,20">
                    <Label Text="🛍️" FontSize="36"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Título -->
                <Label Text="TIENDA"
                       FontSize="38" FontAttributes="Bold"
                       TextColor="#FFD700"
                       HorizontalOptions="Center"
                       CharacterSpacing="6"/>

                <Label Text="Departamental"
                       FontSize="15" TextColor="#B0BEC5"
                       HorizontalOptions="Center"
                       Margin="0,4,0,40"/>

                <!-- Card campos -->
                <Border BackgroundColor="#0D2B45"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        Padding="24,28"
                        Margin="0,0,0,24">
                    <VerticalStackLayout Spacing="16">

                        <!-- Email -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Correo electrónico"
                                   TextColor="#B0BEC5" FontSize="12"
                                   FontAttributes="Bold"/>
                            <Border BackgroundColor="#001F3F"
                                    StrokeThickness="1"
                                    Stroke="#1A3A5C"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="16,4">
                                <Entry Placeholder="tucorreo@email.com"
                                       Text="{Binding Email}"
                                       Keyboard="Email"
                                       PlaceholderColor="#455A6A"
                                       TextColor="White"
                                       BackgroundColor="Transparent"
                                       HeightRequest="44"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Contraseña"
                                   TextColor="#B0BEC5" FontSize="12"
                                   FontAttributes="Bold"/>
                            <Border BackgroundColor="#001F3F"
                                    StrokeThickness="1"
                                    Stroke="#1A3A5C"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="16,4">
                                <Entry Placeholder="••••••••"
                                       Text="{Binding Password}"
                                       IsPassword="True"
                                       PlaceholderColor="#455A6A"
                                       TextColor="White"
                                       BackgroundColor="Transparent"
                                       HeightRequest="44"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Error -->
                        <Border BackgroundColor="#2D0A0F"
                                StrokeThickness="1"
                                Stroke="#E3122B"
                                StrokeShape="RoundRectangle 8"
                                Padding="12,8"
                                IsVisible="{Binding ErrorMensaje, Converter={StaticResource StringToBoolConverter}}">
                            <Label Text="{Binding ErrorMensaje}"
                                   TextColor="#E3122B"
                                   FontSize="13"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <!-- Botón Login -->
                        <Button Text="INICIAR SESIÓN"
                                Command="{Binding LoginCommand}"
                                BackgroundColor="#FFD700"
                                TextColor="#001F3F"
                                FontAttributes="Bold"
                                FontSize="15"
                                HeightRequest="54"
                                CornerRadius="12"
                                Margin="0,8,0,0"/>

                    </VerticalStackLayout>
                </Border>

                <!-- Crear cuenta -->
                <Button Text="Crear cuenta nueva"
                        Command="{Binding IrARegistroCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#FFD700"
                        BorderColor="#FFD700"
                        BorderWidth="1.5"
                        FontAttributes="Bold"
                        FontSize="14"
                        HeightRequest="54"
                        CornerRadius="12"
                        Margin="0,0,0,20"/>

                <!-- Divisor -->
                <Grid ColumnDefinitions="*,Auto,*"
                      ColumnSpacing="12" Margin="0,0,0,20">
                    <BoxView Grid.Column="0" BackgroundColor="#1A3A5C"
                             HeightRequest="1" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="o"
                           TextColor="#455A6A" FontSize="13"/>
                    <BoxView Grid.Column="2" BackgroundColor="#1A3A5C"
                             HeightRequest="1" VerticalOptions="Center"/>
                </Grid>

                <!-- Invitado -->
                <Label HorizontalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Continuar como " TextColor="#B0BEC5" FontSize="14"/>
                            <Span Text="invitado →" TextColor="#FFD700" FontSize="14" FontAttributes="Bold"/>
                        </FormattedString>
                    </Label.FormattedText>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EntrarComoInvitadoCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>